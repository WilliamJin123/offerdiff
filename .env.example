# Supabase — used by /api/subscribe to store email signups.
# Create a free project at https://supabase.com, then create a table:
#
#   create table subscribers (
#     id uuid primary key default gen_random_uuid(),
#     email text not null unique,
#     source text,
#     created_at timestamptz not null default now()
#   );
#
# Use the project URL and the SERVICE ROLE key (server-side only — never expose to the client).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL, used for SEO canonical/OG tags + sitemap. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://offerdiff.vercel.app
